# -----------------------------------------------------------------------------
# Local Development Secrets & API Keys (placeholders)
# -----------------------------------------------------------------------------
# Copy to config/.env and replace values locally. Do not commit real secrets.

DB_PASSWORD=your_db_password
REDIS_PASSWORD=your_redis_password
SESSION_SECRET=your_session_secret

# External Integrations (Sandbox/Dev Keys)
PAYMENT_GATEWAY_API_KEY=your_payment_gateway_key
EMAIL_PROVIDER_TOKEN=your_email_provider_token

# Auth Issuer Secrets
AUTH_CLIENT_SECRET=your_auth_client_secret

# Render API
RenderApiKey=your_render_api_key
RenderOwnerID=your_render_owner_id
